{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile and overall progress state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "class": { "type": "string" },
        "group": { "type": "string" },
        "progress": { 
          "type": "object",
          "properties": {
            "totalSolved": { "type": "number" },
            "accuracy": { "type": "number" },
            "streak": { "type": "number" }
          }
        },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    },
    "Vocabulary": {
      "title": "Vocabulary",
      "description": "System vocabulary containing words, definitions, translations for memorizing",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "language": { "type": "string" },
        "category": { "type": "string" },
        "pronunciation": { "type": "string" },
        "meaning": { "type": "string" },
        "synonyms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "antonyms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "example": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["word", "language", "category", "meaning"]
    },
    "Note": {
      "title": "Note",
      "description": "Dynamic lecture notes created by tutors or administrators.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "classGroup": { "type": "string" },
        "badges": {
          "type": "array",
          "items": { "type": "string" }
        },
        "content": {
          "type": "object",
          "properties": {
            "intro": { "type": "string" },
            "chapters": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "title": { "type": "string" },
                  "items": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "isExternal": { "type": "boolean" },
        "link": { "type": "string" }
      },
      "required": ["title", "subject", "classGroup", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and their cumulative progress."
    },
    "vocabulary/{wordId}": {
      "schema": { "$ref": "#/entities/Vocabulary" },
      "description": "Stores custom system vocabulary items uploaded by the Admin."
    },
    "notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Stores dynamic study guides and lecture notes created by Tutors or Admins."
    }
  }
}
