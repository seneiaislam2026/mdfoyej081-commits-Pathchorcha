{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile and overall progress state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "class": { "type": "string" },
        "group": { "type": "string" },
        "progress": { 
          "type": "object",
          "properties": {
            "totalSolved": { "type": "number" },
            "accuracy": { "type": "number" },
            "streak": { "type": "number" }
          }
        },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    },
    "Vocabulary": {
      "title": "Vocabulary",
      "description": "System vocabulary containing words, definitions, translations for memorizing",
      "type": "object",
      "properties": {
        "word": { "type": "string" },
        "language": { "type": "string" },
        "category": { "type": "string" },
        "pronunciation": { "type": "string" },
        "meaning": { "type": "string" },
        "synonyms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "antonyms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "example": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["word", "language", "category", "meaning"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and their cumulative progress."
    },
    "vocabulary/{wordId}": {
      "schema": { "$ref": "#/entities/Vocabulary" },
      "description": "Stores custom system vocabulary items uploaded by the Admin."
    }
  }
}
