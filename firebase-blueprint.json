{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile and overall progress state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "class": { "type": "string" },
        "group": { "type": "string" },
        "progress": { 
          "type": "object",
          "properties": {
            "totalSolved": { "type": "number" },
            "accuracy": { "type": "number" },
            "streak": { "type": "number" }
          }
        },
        "points": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and their cumulative progress."
    }
  }
}
