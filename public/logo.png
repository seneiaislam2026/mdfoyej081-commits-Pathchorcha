<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 500" width="100%" height="100%">
  <!-- White Background Circle -->
  <circle cx="250" cy="250" r="245" fill="#ffffff" />
  
  <!-- Blue Outer Ring -->
  <circle cx="250" cy="250" r="225" fill="none" stroke="#1b4f9b" stroke-width="15" />
  
  <!-- Red Shield (Outer Book Layer) -->
  <path d="M 250, 128
    C 285, 112 335, 132 380, 110
    C 385, 150 395, 290 380, 380
    C 350, 395 290, 390 250, 424
    C 210, 390 150, 395 120, 380
    C 105, 290 115, 150 120, 110
    C 155, 132 205, 112 250, 128 Z"
    fill="#d2232a" />
  
  <!-- Yellow Shield (Second Layer) -->
  <path d="M 250, 142
    C 282, 128 328, 145 368, 126
    C 373, 162 382, 288 368, 368
    C 341, 381 287, 376 250, 407
    C 213, 376 159, 381 132, 368
    C 118, 288 127, 162 132, 126
    C 164, 145 210, 128 250, 142 Z"
    fill="#ffcd00" />

  <!-- White Shield (Third Layer) -->
  <path d="M 250, 156
    C 279, 144 321, 158 356, 142
    C 361, 174 369, 286 356, 356
    C 332, 367 284, 362 250, 390
    C 216, 362 168, 367 144, 356
    C 131, 286 139, 174 144, 142
    C 169, 158 211, 144 250, 156 Z"
    fill="#ffffff" />

  <!-- Blue Shield (Fourth Layer - Center) -->
  <path d="M 250, 166
    C 277, 154 316, 167 348, 152
    C 353, 182 360, 284 348, 347
    C 325, 357 282, 352 250, 378
    C 218, 352 175, 357 152, 347
    C 140, 284 147, 182 152, 152
    C 174, 167 213, 154 250, 166 Z"
    fill="#1b4f9b" />

  <!-- The white flower/sun emblem in the center -->
  <g fill="#ffffff">
    <!-- Center white hub -->
    <circle cx="250" cy="255" r="28" />
    <!-- 16 sharp petals -->
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(22.5, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(45, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(67.5, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(90, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(112.5, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(135, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(157.5, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(180, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(202.5, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(225, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(247.5, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(270, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(292.5, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(315, 250, 255)" />
    <path d="M 250, 255 C 240, 238 243, 195 250, 175 C 257, 195 260, 238 250, 255 Z" transform="rotate(337.5, 250, 255)" />
  </g>
</svg>
