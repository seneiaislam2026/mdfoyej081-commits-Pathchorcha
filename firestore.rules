rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']);
    }

    function isAdmin() {
      return request.auth != null && request.auth.token != null && request.auth.token.email != null && (request.auth.token.email.lower() == 'mdfoyej081@gmail.com' || request.auth.token.email.lower() == 'seneiaislam@gmail.com');
    }

    function isTutor() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isTutor == true;
    }

    match /users/{userId} {
      allow read: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      
      allow create: if isSignedIn()
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if (isSignedIn()
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time) || isAdmin();
    }

    match /doubts/{doubtId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin() || isTutor());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || isTutor());
    }
  }
}
