rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']);
    }

    function isAdmin() {
      return (request.auth != null && request.auth.token != null && request.auth.token.email != null && (request.auth.token.email == 'mdfoyej081@gmail.com' || request.auth.token.email == 'seneiaislam@gmail.com' || request.auth.token.email.lower() == 'mdfoyej081@gmail.com')) || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    function isTutor() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isTutor == true;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().uid == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if (isSignedIn()
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time) || isAdmin();
        
      allow delete: if isAdmin();
    }

    match /users/{userId}/saved_notes/{noteId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/mistakes/{questionId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/exam_results/{resultId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/routine/{slotId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if true;
    }

    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /doubts/{doubtId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin() || isTutor());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || isTutor());
    }

    match /public_exams/{examId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /public_exam_results/{resultId} {
      allow create, read: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read: if (isAdmin() || isTutor());
      allow update: if (isAdmin() || isTutor());
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /payment_requests/{txnId} {
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /class_change_requests/{requestId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read, write: if isAdmin();
    }

    match /notifications/{notiId} {
      allow create: if isAdmin();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == 'all');
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /vocabulary/{wordId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if true;
      allow write: if isAdmin() || isTutor();
    }

    match /finance_records/{recordId} {
      allow read, write: if isAdmin();
    }
  }
}
